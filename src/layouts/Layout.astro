---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title = 'Blackout Media | Firearms & Tactical Content Production Agency',
  description = 'Blackout Media produces cinematic video content and marketing for the firearms and tactical industry. We speak the culture, built by shooters for brands that demand credibility.',
  ogTitle,
  ogDescription,
  ogImage = '/images/og-default.jpg',
  canonicalUrl,
} = Astro.props;

const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;
const siteUrl = 'https://www.blackout-media.com';
const canonical = canonicalUrl ?? Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Blackout Media" />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <!-- JSON-LD slot for per-page schema overrides -->
    <slot name="schema" />

    <!-- Default Organization schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Blackout Media",
      "url": "https://www.blackout-media.com",
      "logo": "https://www.blackout-media.com/logos/blackout-icon-white.png",
      "description": "Utah's dedicated firearms marketing agency specializing in social media content, video production, and website strategy for gun manufacturers, ranges, and training companies.",
      "telephone": "801-900-3251",
      "email": "info@blackout-media.com",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "801-900-3251",
        "email": "info@blackout-media.com",
        "contactType": "customer service"
      },
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "UT",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "State",
        "name": "Utah"
      }
    }
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ED66WQGL1T"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ED66WQGL1T');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
