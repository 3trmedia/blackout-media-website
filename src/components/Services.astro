---
const services = [
  {
    title: "Grow Your\nSocial Media",
    desc: "Platform-compliant content that builds real audiences without triggering shadowbans, flags, or restrictions.",
    img: "/images/services-social.jpg",
    href: "/services/social-media",
  },
  {
    title: "Fill Your\nCourses",
    desc: "Targeted video campaigns that put your training programs in front of qualified students ready to enroll.",
    img: "/images/services-courses.jpg",
    href: "/services/courses",
  },
  {
    title: "Highlight Your\nProducts",
    desc: "Photo and video that showcases your gear the way it deserves: sharp, professional, and built to convert.",
    img: "/images/services-products.jpg",
    href: "/services/products",
  },
  {
    title: "Increase Your\nSales",
    desc: "Full-funnel strategies that turn your website and social presence into a consistent revenue engine.",
    img: "/images/services-sales.jpg",
    href: "/services/sales",
  },
];
---

<section id="services" class="relative bg-black-950">

  <!-- 1:1 square grid, flush edge to edge -->
  <div class="grid grid-cols-2 lg:grid-cols-4">
    {services.map((s) => (
      <a
        href={s.href}
        class="relative group overflow-hidden aspect-square block"
      >
        <img
          src={s.img}
          alt={s.title.replace('\n', ' ')}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <!-- Permanent dark overlay for readability -->
        <div class="absolute inset-0 bg-black-950/25"></div>
        <!-- Brass tint on hover -->
        <div class="absolute inset-0 bg-brass-500/0 group-hover:bg-brass-500/10 transition-colors duration-400"></div>

        <!-- Label: centered, slides up on hover, description appears below -->
        <div class="absolute inset-0 flex flex-col items-center justify-center px-4 text-center group-hover:-translate-y-4 transition-transform duration-300">
          <h3
            class="text-white-100 font-bold text-3xl md:text-4xl uppercase tracking-wide leading-tight whitespace-pre-line"
            style="text-shadow: 0 2px 16px rgba(0,0,0,0.85), 0 1px 4px rgba(0,0,0,0.9);"
          >
            {s.title}
          </h3>
          <p
            class="text-white-100/90 text-sm md:text-base leading-relaxed mt-4 max-h-0 overflow-hidden opacity-0 group-hover:max-h-24 group-hover:opacity-100 transition-all duration-300 delay-75 max-w-xs"
            style="text-shadow: 0 1px 8px rgba(0,0,0,0.9);"
          >
            {s.desc}
          </p>
        </div>
      </a>
    ))}
  </div>

</section>
