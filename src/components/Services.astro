---
const services = [
  { title: "Grow Your\nSocial Media",  img: "/images/services-social.jpg",   href: "/services/social-media" },
  { title: "Fill Your\nCourses",        img: "/images/services-courses.jpg",  href: "/services/courses" },
  { title: "Highlight Your\nProducts",  img: "/images/services-products.jpg", href: "/services/products" },
  { title: "Increase Your\nSales",      img: "/images/services-sales.jpg",    href: "/services/sales" },
];
---

<section id="services" class="relative bg-black-950">

  <!-- Gradient bridge from hero -->
  <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-black-950 to-transparent pointer-events-none z-10"></div>

  <!-- 1:1 square grid, flush edge to edge -->
  <div class="grid grid-cols-2 lg:grid-cols-4">
    {services.map((s) => (
      <a
        href={s.href}
        class="relative group overflow-hidden aspect-square block"
      >
        <img
          src={s.img}
          alt={s.title.replace('\n', ' ')}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <!-- Dark gradient bottom -->
        <div class="absolute inset-0 bg-gradient-to-t from-black-950/90 via-black-950/30 to-transparent"></div>
        <!-- Brass tint on hover -->
        <div class="absolute inset-0 bg-brass-500/0 group-hover:bg-brass-500/15 transition-colors duration-400"></div>
        <!-- Label -->
        <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
          <div class="w-6 h-0.5 bg-brass-500 mb-3"></div>
          <h3 class="text-white-100 font-bold text-sm md:text-base uppercase tracking-widest leading-snug whitespace-pre-line">
            {s.title}
          </h3>
        </div>
      </a>
    ))}
  </div>

</section>
