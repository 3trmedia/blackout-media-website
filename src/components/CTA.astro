---
---

<section class="relative py-28 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img src="/images/cta-bg.jpg" alt="" class="w-full h-full object-cover opacity-20" />
    <div class="absolute inset-0 bg-black-950/80"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <p class="text-brass-500 text-xs font-bold uppercase tracking-[0.3em] mb-4">Ready to Scale?</p>
    <h2 class="text-4xl md:text-5xl font-black text-white-100 leading-tight mb-6">
      Ready to Transform Your <span class="text-brass-500">Social Media Presence?</span>
    </h2>
    <p class="text-white-200/65 text-lg max-w-2xl mx-auto mb-10">
      Schedule a free 30-minute strategy call. No obligations — just practical advice you can implement today, whether you hire us or not.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12 text-left">
      {[
        { icon: "🎯", title: "Free Strategy Call", desc: "30 minutes of real, actionable advice — no sales pitch." },
        { icon: "📈", title: "Custom Growth Plan", desc: "A tailored overview built around your specific goals." },
        { icon: "⚡", title: "Clear Next Steps", desc: "Walk away knowing exactly what to do next." },
      ].map((item) => (
        <div class="flex items-start gap-4 bg-white-100/5 border border-white-100/8 p-5">
          <span class="text-2xl">{item.icon}</span>
          <div>
            <p class="text-white-100 font-bold text-sm mb-1">{item.title}</p>
            <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <a href="#contact" class="inline-block bg-brass-500 hover:bg-brass-400 text-black-950 font-black px-10 py-4 uppercase tracking-wider text-sm transition-colors">
      Get Your Free Strategy Call
    </a>
  </div>
</section>
