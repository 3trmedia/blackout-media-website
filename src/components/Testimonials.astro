---
const testimonials = [
  {
    quote: "Blackout Media is truly passionate about the photos and videos they create, and it shows in the marketing results.",
    name: "Wesley R.",
    company: "RH Borden Construction",
    initials: "WR",
  },
  {
    quote: "Ben is talented, professional, and flexible. He offers creative ideas and exceptional support. Highly recommend.",
    name: "Sarah M.",
    company: "Board of Provo",
    initials: "SM",
  },
  {
    quote: "The attention to detail is incredible. The level of professionalism was outstanding throughout our entire project.",
    name: "James T.",
    company: "Uptown Drapes",
    initials: "JT",
  },
  {
    quote: "They understand the firearms industry in a way most agencies never will. No flags, no headaches. Just growth.",
    name: "Easton C.",
    company: "Iron Rescue",
    initials: "EC",
  },
  {
    quote: "Our course enrollment jumped after the first video campaign. These guys know how to reach our audience.",
    name: "Noah K.",
    company: "The Art Room",
    initials: "NK",
  },
  {
    quote: "From strategy to execution, Blackout Media delivered on every promise. Our social following tripled in 3 months.",
    name: "Lisa B.",
    company: "Brightland Interiors",
    initials: "LB",
  },
];
---

<section class="bg-black-900 py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">

    <div class="text-center mb-14">
      <p class="text-brass-500 text-xs font-bold uppercase tracking-[0.3em] mb-3">Client Results</p>
      <h2 class="text-4xl md:text-5xl font-black text-white-100">What Our Clients Say</h2>
    </div>

    <!-- Carousel -->
    <div class="relative">
      <div id="testimonial-track" class="grid grid-cols-1 md:grid-cols-3 gap-6 transition-all duration-500">
        {testimonials.slice(0, 3).map((t) => (
          <div class="bg-black-800 border border-white-100/5 p-8 flex flex-col gap-5">
            <div class="flex gap-1">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 text-brass-500 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-white-200/75 leading-relaxed text-sm flex-1">"{t.quote}"</p>
            <div class="flex items-center gap-3 pt-4 border-t border-white-100/5">
              <div class="w-10 h-10 rounded-full bg-brass-500/20 border border-brass-500/30 flex items-center justify-center flex-shrink-0">
                <span class="text-brass-500 font-bold text-xs">{t.initials}</span>
              </div>
              <div>
                <p class="text-white-100 font-semibold text-sm">{t.name}</p>
                <p class="text-gray-400 text-xs">{t.company}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation dots -->
      <div class="flex justify-center gap-2 mt-8">
        <button id="dot-0" class="w-6 h-1 bg-brass-500 transition-all" aria-label="Slide 1"></button>
        <button id="dot-1" class="w-2 h-1 bg-white-100/20 hover:bg-white-100/40 transition-all" aria-label="Slide 2"></button>
      </div>
    </div>

  </div>
</section>

<script>
  const all = [
    { quote: "Blackout Media is truly passionate about the photos and videos they create, and it shows in the marketing results.", name: "Wesley R.", company: "RH Borden Construction", initials: "WR" },
    { quote: "Ben is talented, professional, and flexible. He offers creative ideas and exceptional support. Highly recommend.", name: "Sarah M.", company: "Board of Provo", initials: "SM" },
    { quote: "The attention to detail is incredible. The level of professionalism was outstanding throughout our entire project.", name: "James T.", company: "Uptown Drapes", initials: "JT" },
    { quote: "They understand the firearms industry in a way most agencies never will. No flags, no headaches. Just growth.", name: "Easton C.", company: "Iron Rescue", initials: "EC" },
    { quote: "Our course enrollment jumped after the first video campaign. These guys know how to reach our audience.", name: "Noah K.", company: "The Art Room", initials: "NK" },
    { quote: "From strategy to execution, Blackout Media delivered on every promise. Our social following tripled in 3 months.", name: "Lisa B.", company: "Brightland Interiors", initials: "LB" },
  ];

  const slides = [[0,1,2],[3,4,5]];
  let current = 0;

  function renderSlide(idx) {
    const track = document.getElementById('testimonial-track');
    if (!track) return;
    track.innerHTML = slides[idx].map(i => `
      <div class="bg-black-800 border border-white-100/5 p-8 flex flex-col gap-5">
        <div class="flex gap-1">${'<svg class="w-4 h-4 text-brass-500 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'.repeat(5)}</div>
        <p class="text-white-200/75 leading-relaxed text-sm flex-1">"${all[i].quote}"</p>
        <div class="flex items-center gap-3 pt-4 border-t border-white-100/5">
          <div class="w-10 h-10 rounded-full bg-brass-500/20 border border-brass-500/30 flex items-center justify-center flex-shrink-0">
            <span class="text-brass-500 font-bold text-xs">${all[i].initials}</span>
          </div>
          <div>
            <p class="text-white-100 font-semibold text-sm">${all[i].name}</p>
            <p class="text-gray-400 text-xs">${all[i].company}</p>
          </div>
        </div>
      </div>`).join('');

    document.getElementById('dot-0')?.classList.toggle('w-6', idx === 0);
    document.getElementById('dot-0')?.classList.toggle('bg-brass-500', idx === 0);
    document.getElementById('dot-0')?.classList.toggle('w-2', idx !== 0);
    document.getElementById('dot-0')?.classList.toggle('bg-white-100/20', idx !== 0);
    document.getElementById('dot-1')?.classList.toggle('w-6', idx === 1);
    document.getElementById('dot-1')?.classList.toggle('bg-brass-500', idx === 1);
    document.getElementById('dot-1')?.classList.toggle('w-2', idx !== 1);
    document.getElementById('dot-1')?.classList.toggle('bg-white-100/20', idx !== 1);
  }

  document.getElementById('dot-0')?.addEventListener('click', () => { current = 0; renderSlide(0); });
  document.getElementById('dot-1')?.addEventListener('click', () => { current = 1; renderSlide(1); });
</script>
