---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">

  <!-- YouTube video background -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <iframe
      id="hero-video"
      src="https://www.youtube.com/embed/Xt1wZXrDSKs?autoplay=1&mute=1&loop=1&playlist=Xt1wZXrDSKs&controls=0&showinfo=0&rel=0&iv_load_policy=3&modestbranding=1&playsinline=1"
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
      style="width: 177.78vh; min-width: 100%; height: 56.25vw; min-height: 100%;"
      frameborder="0"
      allow="autoplay; encrypted-media"
      title="Background video"
    ></iframe>
    <img
      src="/images/hero-poster.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-50 transition-opacity duration-1000"
      id="hero-poster"
    />
    <div class="absolute inset-0 bg-black-950/60"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black-950"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-28 pb-24 text-center">

    <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.35em] mb-5 font-sans">
      Utah's Dedicated Firearms Marketing Agency
    </p>

    <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white-100 leading-[1.08] mb-6">
      More Sales.<br />
      More Customers.<br />
      <span class="text-brass-500">More Courses Filled.</span>
    </h1>

    <p class="text-lg md:text-xl text-white-200/65 max-w-2xl mx-auto mb-12 leading-relaxed font-sans">
      Blackout Media produces the content, social strategy, and digital presence that gun manufacturers, ranges, and training companies need to grow — without getting flagged, shadow banned, or outpaced.
    </p>

    <!-- Separated square buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-5">
      <a
        href="#contact"
        class="bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-10 py-4 uppercase tracking-[0.15em] text-sm transition-colors w-full sm:w-56 text-center font-sans"
      >
        Work With Us
      </a>
      <a
        href="#work"
        class="border-2 border-white-100/30 hover:border-brass-500 hover:text-brass-500 text-white-100 font-bold px-10 py-4 uppercase tracking-[0.15em] text-sm transition-colors w-full sm:w-56 text-center font-sans"
      >
        See Our Work
      </a>
    </div>

    <!-- Trusted by -->
    <div class="mt-20 pt-10 border-t border-white-100/10">
      <p class="text-white-200/35 text-xs uppercase tracking-[0.3em] mb-8 font-sans">Trusted By</p>
      <div class="flex items-center justify-center gap-10 md:gap-14 flex-wrap">
        <img src="/logos/ntac-logo-shield-3d.png"     alt="NTAC"           class="h-14 object-contain opacity-55 hover:opacity-85 transition-opacity" />
        <img src="/logos/iron-rescue-logo.png"         alt="Iron Rescue"    class="h-11 object-contain opacity-55 hover:opacity-85 transition-opacity" />
        <img src="/logos/ft-logo_white_280x80_1.png"  alt="First Tactical" class="h-10 object-contain opacity-55 hover:opacity-85 transition-opacity" />
        <img src="/logos/white-logo-axil.png"          alt="AXIL"           class="h-10 object-contain opacity-55 hover:opacity-85 transition-opacity" />
      </div>
    </div>

  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="w-5 h-5 text-brass-500/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>

</section>

<script>
  const poster = document.getElementById('hero-poster');
  const video = document.getElementById('hero-video');
  if (video && poster) {
    video.addEventListener('load', () => {
      setTimeout(() => { (poster as HTMLElement).style.opacity = '0'; }, 1200);
    });
  }
</script>
