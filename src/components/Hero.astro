---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">

  <!-- YouTube video background -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <iframe
      id="hero-video"
      src="https://www.youtube.com/embed/Xt1wZXrDSKs?autoplay=1&mute=1&loop=1&playlist=Xt1wZXrDSKs&controls=0&showinfo=0&rel=0&iv_load_policy=3&modestbranding=1&playsinline=1"
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
      style="width: 177.78vh; min-width: 100%; height: 56.25vw; min-height: 100%;"
      frameborder="0"
      allow="autoplay; encrypted-media"
      title="Background video"
    ></iframe>
    <!-- Fallback poster shown before video loads -->
    <img
      src="/images/hero-poster.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-50"
      id="hero-poster"
    />
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-black-950/65"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black-950"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-28 pb-24 text-center">

    <p class="text-brass-500 text-xs font-bold uppercase tracking-[0.3em] mb-5">
      Utah's Dedicated Firearms Marketing Agency
    </p>

    <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white-100 leading-[1.05] mb-6">
      More Sales.<br />
      More Customers.<br />
      <span class="text-brass-500">More Courses Filled.</span>
    </h1>

    <p class="text-lg md:text-xl text-white-200/70 max-w-2xl mx-auto mb-10 leading-relaxed">
      Blackout Media produces the content, social strategy, and digital presence that gun manufacturers, ranges, and training companies need to grow — without getting flagged, shadow banned, or outpaced.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#work" class="bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-8 py-4 uppercase tracking-wider text-sm transition-colors w-full sm:w-auto text-center">
        See Our Work
      </a>
      <a href="#contact" class="border border-white-100/25 hover:border-brass-500 text-white-100 hover:text-brass-500 font-bold px-8 py-4 uppercase tracking-wider text-sm transition-colors w-full sm:w-auto text-center">
        Work With Us
      </a>
    </div>

    <!-- Trusted by -->
    <div class="mt-16 pt-12 border-t border-white-100/10">
      <p class="text-white-200/40 text-xs uppercase tracking-[0.25em] mb-8">Trusted By</p>
      <div class="flex items-center justify-center gap-10 md:gap-16 flex-wrap">
        <img src="/logos/ntac-logo-shield-3d.png" alt="NTAC" class="h-10 object-contain opacity-50 hover:opacity-80 transition-opacity" />
        <img src="/logos/iron-rescue-logo.png" alt="Iron Rescue" class="h-8 object-contain opacity-50 hover:opacity-80 transition-opacity" />
        <img src="/logos/ft-logo_white_280x80_1.png" alt="First Tactical" class="h-7 object-contain opacity-50 hover:opacity-80 transition-opacity" />
        <img src="/logos/white-logo-axil.png" alt="AXIL" class="h-7 object-contain opacity-50 hover:opacity-80 transition-opacity" />
      </div>
    </div>

  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="w-5 h-5 text-brass-500/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>

</section>

<script>
  // Hide poster once video iframe is ready
  const poster = document.getElementById('hero-poster');
  const video = document.getElementById('hero-video');
  if (video && poster) {
    video.addEventListener('load', () => {
      setTimeout(() => poster.style.opacity = '0', 1000);
    });
  }
</script>
