---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">

  <!-- Video background -->
  <div class="absolute inset-0 z-0">
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover opacity-40"
      poster="/images/hero-poster.jpg"
    >
      <!-- Replace src with real video file when available -->
      <source src="/videos/hero-bg.mp4" type="video/mp4" />
    </video>
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black-950/60 via-black-950/40 to-black-950"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-24 pb-20 text-center">

    <p class="text-brass-500 text-sm font-bold uppercase tracking-[0.25em] mb-6">
      Utah's Dedicated Firearms Marketing Agency
    </p>

    <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white-100 leading-tight mb-6">
      More Sales.<br />
      More Customers.<br />
      <span class="text-brass-500">More Courses Filled.</span>
    </h1>

    <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Blackout Media produces the content, social strategy, and digital presence that gun manufacturers, ranges, and training companies need to grow — without getting flagged, shadow banned, or outpaced.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#work" class="bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-8 py-4 uppercase tracking-wider text-sm transition-colors w-full sm:w-auto text-center">
        See Our Work
      </a>
      <a href="#contact" class="border border-white-100/20 hover:border-brass-500 text-white-100 hover:text-brass-500 font-bold px-8 py-4 uppercase tracking-wider text-sm transition-colors w-full sm:w-auto text-center">
        Work With Us
      </a>
    </div>

    <!-- Trusted by -->
    <div class="mt-16">
      <p class="text-gray-400 text-xs uppercase tracking-[0.2em] mb-6">Trusted By</p>
      <div class="flex items-center justify-center gap-8 md:gap-12 flex-wrap">
        <span class="text-white-200/40 font-bold text-sm uppercase tracking-widest hover:text-white-200/70 transition-colors">NTAC</span>
        <span class="text-white-200/40 font-bold text-sm uppercase tracking-widest hover:text-white-200/70 transition-colors">Iron Rescue</span>
        <span class="text-white-200/40 font-bold text-sm uppercase tracking-widest hover:text-white-200/70 transition-colors">First Tactical</span>
        <span class="text-white-200/40 font-bold text-sm uppercase tracking-widest hover:text-white-200/70 transition-colors">AXIL</span>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="w-5 h-5 text-brass-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>

</section>
