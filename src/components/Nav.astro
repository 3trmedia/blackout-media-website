<nav class="fixed top-0 left-0 right-0 z-50 bg-black-950/90 backdrop-blur-sm border-b border-white-100/5">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16">

    <a href="/" class="text-white-100 font-bold text-lg tracking-wider uppercase">
      Blackout Media
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a href="#work" class="text-gray-400 hover:text-white-100 text-sm font-medium transition-colors uppercase tracking-wider">Work</a>
      <a href="#services" class="text-gray-400 hover:text-white-100 text-sm font-medium transition-colors uppercase tracking-wider">Services</a>
      <a href="#about" class="text-gray-400 hover:text-white-100 text-sm font-medium transition-colors uppercase tracking-wider">About</a>
      <a href="#contact" class="bg-brass-500 hover:bg-brass-400 text-black-950 text-sm font-bold px-5 py-2 uppercase tracking-wider transition-colors">
        Work With Us
      </a>
    </div>

    <!-- Mobile menu button -->
    <button class="md:hidden text-gray-400 hover:text-white-100" id="mobile-menu-btn" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden bg-black-900 border-t border-white-100/5" id="mobile-menu">
    <div class="px-6 py-4 flex flex-col gap-4">
      <a href="#work" class="text-gray-400 hover:text-white-100 text-sm font-medium uppercase tracking-wider">Work</a>
      <a href="#services" class="text-gray-400 hover:text-white-100 text-sm font-medium uppercase tracking-wider">Services</a>
      <a href="#about" class="text-gray-400 hover:text-white-100 text-sm font-medium uppercase tracking-wider">About</a>
      <a href="#contact" class="bg-brass-500 text-black-950 text-sm font-bold px-5 py-2 uppercase tracking-wider text-center">Work With Us</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
