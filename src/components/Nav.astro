---
const navLinks = [
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const serviceLinks = [
  { label: 'Social Media', href: '/services/social-media' },
  { label: 'Course Marketing', href: '/services/courses' },
  { label: 'Product Media', href: '/services/products' },
  { label: 'Website Conversions', href: '/services/website-conversions' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-black-950/90 backdrop-blur-sm border-b border-white-100/5">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16">

    <a href="/" class="text-white-100 font-bold text-lg tracking-wider uppercase font-heading">
      Blackout Media
    </a>

    <div class="hidden md:flex items-center gap-8">

      <!-- Services dropdown -->
      <div class="relative group">
        <button class="text-gray-400 hover:text-white-100 text-sm font-medium transition-colors uppercase tracking-wider flex items-center gap-1">
          Services
          <svg class="w-3 h-3 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute top-full left-0 mt-2 w-52 bg-black-900 border border-white-100/10 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          {serviceLinks.map((s) => (
            <a
              href={s.href}
              class="block px-5 py-3 text-gray-400 hover:text-white-100 hover:bg-white-100/5 text-xs uppercase tracking-wider transition-colors border-b border-white-100/5 last:border-0"
            >
              {s.label}
            </a>
          ))}
        </div>
      </div>

      {navLinks.map((l) => (
        <a href={l.href} class="text-gray-400 hover:text-white-100 text-sm font-medium transition-colors uppercase tracking-wider">
          {l.label}
        </a>
      ))}

      <a href="/contact" class="bg-brass-500 hover:bg-brass-400 text-black-950 text-sm font-bold px-5 py-2 uppercase tracking-wider transition-colors">
        Work With Us
      </a>
    </div>

    <!-- Mobile menu button -->
    <button class="md:hidden text-gray-400 hover:text-white-100" id="mobile-menu-btn" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden bg-black-900 border-t border-white-100/5" id="mobile-menu">
    <div class="px-6 py-4 flex flex-col gap-1">
      <p class="text-white-200/30 text-xs uppercase tracking-wider py-2">Services</p>
      {serviceLinks.map((s) => (
        <a href={s.href} class="text-gray-400 hover:text-white-100 text-sm font-medium uppercase tracking-wider py-2 pl-3 border-l border-white-100/10">
          {s.label}
        </a>
      ))}
      <div class="border-t border-white-100/5 my-2"></div>
      {navLinks.map((l) => (
        <a href={l.href} class="text-gray-400 hover:text-white-100 text-sm font-medium uppercase tracking-wider py-2">
          {l.label}
        </a>
      ))}
      <a href="/contact" class="mt-2 bg-brass-500 text-black-950 text-sm font-bold px-5 py-3 uppercase tracking-wider text-center">
        Work With Us
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
