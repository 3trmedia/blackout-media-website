---
const services = [
  {
    title: "Social Media Marketing",
    desc: "Platform-specific strategy and content that builds your audience and keeps you visible.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.14 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />`,
  },
  {
    title: "Commercial Videography",
    desc: "Cinematic production that captures your brand, your gear, and your story on location.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" />`,
  },
  {
    title: "Course & Class Marketing",
    desc: "Content systems built to fill seats and turn your expertise into a brand people trust.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />`,
  },
  {
    title: "Product Photography & Video",
    desc: "Professional visuals that make your gear look worth buying across every platform.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><circle cx="12" cy="13" r="3" stroke-width="1.5" />`,
  },
  {
    title: "Website Design & SEO",
    desc: "Sites built to rank, convert, and represent your brand the way it deserves.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />`,
  },
  {
    title: "Graphic Design & Branding",
    desc: "Logos, mockups, email design, and visual identity that makes your brand instantly recognizable.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />`,
  },
];
---

<section class="bg-black-950 py-24 border-t border-white-100/5">
  <div class="max-w-7xl mx-auto px-6">

    <div class="mb-14">
      <p class="text-brass-500 text-xs font-bold uppercase tracking-[0.3em] mb-3 font-sans">What We Offer</p>
      <h2 class="text-4xl md:text-5xl font-black text-white-100">Everything Your Brand Needs to Grow.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white-100/5">
      {services.map((s) => (
        <div class="bg-black-950 p-10 group hover:bg-black-900 transition-colors duration-300">
          <div class="text-brass-500 mb-6">
            <svg class="w-9 h-9" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={s.icon} />
          </div>
          <h3 class="text-white-100 font-bold text-lg mb-3 font-heading">{s.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed font-sans">{s.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
