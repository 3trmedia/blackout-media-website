---
---

<section id="contact" class="bg-black-900 py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left -->
      <div>
        <p class="text-brass-500 text-xs font-bold uppercase tracking-[0.3em] mb-4">Get Started</p>
        <h2 class="text-4xl md:text-5xl font-black text-white-100 leading-tight mb-6">
          Let's Talk About Your Business
        </h2>
        <p class="text-white-200/65 text-lg leading-relaxed mb-10">
          Fill out the form and we'll get back to you within 24 hours. No spam, no pressure — just a real conversation about what's possible.
        </p>

        <div class="space-y-5">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-brass-500/10 border border-brass-500/30 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-brass-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-gray-400 text-xs uppercase tracking-wider mb-0.5">Phone</p>
              <a href="tel:8019003251" class="text-white-100 font-semibold hover:text-brass-500 transition-colors">801-900-3251</a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-brass-500/10 border border-brass-500/30 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-brass-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-gray-400 text-xs uppercase tracking-wider mb-0.5">Email</p>
              <a href="mailto:info@blackoutmedia.com" class="text-white-100 font-semibold hover:text-brass-500 transition-colors">info@blackoutmedia.com</a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-brass-500/10 border border-brass-500/30 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-brass-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-gray-400 text-xs uppercase tracking-wider mb-0.5">Response Time</p>
              <p class="text-white-100 font-semibold">Within 24 hours</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form -->
      <form class="space-y-4" name="contact" method="POST" data-netlify="true">
        <div>
          <label class="block text-white-200/60 text-xs uppercase tracking-wider mb-2" for="name">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Your name"
            class="w-full bg-black-800 border border-white-100/10 focus:border-brass-500 text-white-100 placeholder-gray-400 px-4 py-3 outline-none transition-colors text-sm"
          />
        </div>
        <div>
          <label class="block text-white-200/60 text-xs uppercase tracking-wider mb-2" for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="your@email.com"
            class="w-full bg-black-800 border border-white-100/10 focus:border-brass-500 text-white-100 placeholder-gray-400 px-4 py-3 outline-none transition-colors text-sm"
          />
        </div>
        <div>
          <label class="block text-white-200/60 text-xs uppercase tracking-wider mb-2" for="website">Website or Social</label>
          <input
            type="text"
            id="website"
            name="website"
            placeholder="yoursite.com or @handle"
            class="w-full bg-black-800 border border-white-100/10 focus:border-brass-500 text-white-100 placeholder-gray-400 px-4 py-3 outline-none transition-colors text-sm"
          />
        </div>
        <div>
          <label class="block text-white-200/60 text-xs uppercase tracking-wider mb-2" for="message">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Tell us about your business and what you're looking to achieve..."
            class="w-full bg-black-800 border border-white-100/10 focus:border-brass-500 text-white-100 placeholder-gray-400 px-4 py-3 outline-none transition-colors text-sm resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-brass-500 hover:bg-brass-400 text-black-950 font-black py-4 uppercase tracking-wider text-sm transition-colors flex items-center justify-center gap-2"
        >
          Send Message
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
      </form>

    </div>
  </div>
</section>
