---
---

<section id="about" class="bg-black-950 py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text -->
      <div>
        <p class="text-brass-500 text-xs font-bold uppercase tracking-[0.3em] mb-4">Our Approach</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white-100 leading-tight mb-6">
          We Market. You Operate.
        </h2>
        <p class="text-white-200/65 text-lg leading-relaxed mb-10">
          You built this business to do what you do best, not to spend your evenings figuring out what to post. We step in as your full marketing team so you can stay focused on what actually moves the needle.
        </p>

        <!-- Bullet grid -->
        <div class="grid grid-cols-2 gap-x-8 gap-y-3.5 mb-10">
          {[
            "No Templates. Every Post Is Custom.",
            "Google SEO Ranking",
            "Content Filmed on Location",
            "Tailored Social Media Strategy",
            "Monthly Analytics Review",
            "One Point of Contact. Full Coverage.",
          ].map((item) => (
            <div class="flex items-start gap-2.5">
              <svg class="w-4 h-4 text-brass-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-white-200/70 text-sm leading-snug font-sans">{item}</span>
            </div>
          ))}
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-10 pb-10 border-b border-white-100/8">
          {[
            { number: "62+",  label: "Brands Helped" },
            { number: "4.8M+", label: "Total Views" },
            { number: "$2M+", label: "Revenue Generated" },
            { number: "5+",   label: "Years in the Industry" },
          ].map((stat) => (
            <div>
              <p class="text-2xl md:text-3xl font-black text-brass-500 leading-none">{stat.number}</p>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-2 font-sans leading-snug">{stat.label}</p>
            </div>
          ))}
        </div>

        <!-- Buttons -->
        <div class="flex flex-row flex-wrap gap-3">
          <a
            href="#contact"
            class="bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-8 py-3.5 uppercase tracking-[0.15em] text-sm transition-colors font-sans"
          >
            Ready to Get Started?
          </a>
          <a
            href="/portfolio"
            class="border border-white-100/40 hover:border-brass-500 hover:text-brass-500 text-white-100 font-bold px-8 py-3.5 uppercase tracking-[0.15em] text-sm transition-colors font-sans"
          >
            See Our Work
          </a>
        </div>
      </div>

      <!-- Photo -->
      <div class="relative">
        <div class="absolute -top-4 -left-4 w-full h-full border border-brass-500/20"></div>
        <img
          src="/images/about-photo.jpg"
          alt="Blackout Media in the field"
          class="relative w-full aspect-[4/5] object-cover"
        />
        <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-black-950/80 to-transparent"></div>
      </div>

    </div>
  </div>
</section>
