---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Social Media | Blackout Media" description="We build and manage social media for firearms brands that can't afford to get flagged, shadowbanned, or ignored.">
  <Nav />
  <main>

    <!-- 1. HERO -->
    <section class="relative min-h-[80vh] flex items-center overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/services-social.jpg" alt="Social Media for Firearms Brands" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black-950/70"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black-950/85 via-black-950/50 to-black-950/20"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 pt-24">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white-100 leading-tight mb-5 max-w-3xl">
          Time to Give Your Brand the Spotlight It Deserves.
        </h1>
        <h2 class="text-2xl md:text-3xl font-medium text-white-200/70 mb-10 max-w-xl leading-snug">
          We Handle the Content. You Build the Reputation.
        </h2>
        <a href="/contact" class="inline-flex items-center gap-2 bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-8 py-4 uppercase tracking-wider text-sm transition-colors font-sans">
          Let's Talk
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>

    <!-- 2. PROBLEM STATEMENT — SPLIT -->
    <section class="bg-black-950 border-t border-white-100/5">
      <div class="grid grid-cols-1 lg:grid-cols-2">

        <!-- Image -->
        <div class="relative min-h-[420px] lg:min-h-0">
          <img src="/images/about-action.jpg" alt="Filming on location" class="w-full h-full object-cover absolute inset-0" />
          <div class="absolute inset-0 bg-black-950/25"></div>
        </div>

        <!-- Text -->
        <div class="px-10 lg:px-16 py-20 flex flex-col justify-center bg-black-950">
          <h2 class="text-3xl md:text-4xl font-bold text-white-100 leading-tight mb-5">
            You Run Your Business.<br />We'll Create the Content.
          </h2>
          <p class="text-white-200/60 text-lg font-sans leading-relaxed mb-8">
            Most brands know they need to post. Few have the time or the expertise to do it right. We close that gap — without pulling you away from the work that actually runs your business.
          </p>
          <div class="flex flex-col gap-4">
            {[
              "Platform-compliant content built specifically for the firearms space",
              "Consistent posting without touching your schedule",
              "Messaging that builds your brand and moves people to act",
            ].map((item) => (
              <div class="flex items-start gap-4">
                <div class="w-5 h-5 rounded-full bg-brass-500/15 border border-brass-500/40 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-brass-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="text-white-200/70 text-base font-sans leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- 3. WORK EXAMPLES GRID -->
    <section class="bg-black-900 py-20 border-t border-white-100/5">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-10 font-sans">Work Examples</p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {[
            { img: '/images/still-1.jpg',          client: 'NTAC' },
            { img: '/images/still-2.jpg',          client: 'Iron Rescue' },
            { img: '/images/still-3.jpg',          client: 'The Art Room' },
            { img: '/images/services-social.jpg',  client: 'NTAC' },
            { img: '/images/about-action.jpg',     client: 'Peak Defense Works' },
            { img: '/images/noah-rifle.jpg',       client: 'Iron Rescue' },
          ].map((item) => (
            <div>
              <div class="aspect-video overflow-hidden bg-black-800">
                <img src={item.img} alt={item.client} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
              </div>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-3 font-sans">{item.client}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. WHAT'S INCLUDED — 6 ICON CARDS -->
    <section class="bg-black-950 py-20 border-t border-white-100/5">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">What's Included</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white-100 mb-14">Everything You Need. Nothing You Don't.</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white-100/5">

          <!-- Card 1 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Content Strategy and Planning</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">A monthly roadmap built around your brand, your audience, and what's actually working.</p>
          </div>

          <!-- Card 2 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Filming Coordination and Shot Direction</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">We handle the shoot, locations, angles, timing — so you just show up and do what you do.</p>
          </div>

          <!-- Card 3 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Editing and Platform Optimization</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Every clip cut and formatted for the platform it lives on. No recycled content, no lazy reposts.</p>
          </div>

          <!-- Card 4 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Posting and Scheduling</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Consistent presence without you lifting a finger. We handle the calendar, the captions, everything.</p>
          </div>

          <!-- Card 5 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Brand Partnership Integration</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Sponsorships and partnerships woven naturally into your content without feeling like an ad.</p>
          </div>

          <!-- Card 6 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Analytics and Performance Tracking</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Monthly reporting on what's growing, what's working, and where we push next.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- 5. CONTACT FORM -->
    <Contact />

  </main>
  <Footer />
</Layout>
