---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Course & Class Marketing for Utah Tactical Trainers | Blackout Media"
  description="Blackout Media helps firearms instructors and tactical training companies across Utah fill seats with targeted video campaigns, social funnels, and content built around your curriculum."
  ogTitle="Fill Your Courses | Tactical Training Marketing | Blackout Media Utah"
  ogDescription="Blackout Media helps firearms instructors and tactical training companies across Utah fill seats with targeted video campaigns, social funnels, and content built around your curriculum."
  canonicalUrl="https://www.blackout-media.com/services/courses"
>
  <Nav />
  <main>

    <!-- 1. HERO -->
    <section class="relative min-h-[37vh] flex items-center overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/services-courses.jpg" alt="Course Marketing for Firearms Training" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black-950/70"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black-950/85 via-black-950/50 to-black-950/20"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 pt-20 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white-100 leading-tight mb-5 max-w-4xl mx-auto">
          Your Course Fills Seats When People Know It Exists.
        </h1>
        <h2 class="text-lg md:text-xl font-medium text-white-200/70 whitespace-nowrap mb-5">
          We Build the Demand. You Run the Class.
        </h2>
      </div>
    </section>

    <!-- 2. PROBLEM STATEMENT: SPLIT -->
    <section class="bg-black-950 border-t border-white-100/5">
      <div class="grid grid-cols-1 lg:grid-cols-2">

        <!-- Image -->
        <div class="relative min-h-[500px] lg:min-h-0">
          <img src="/images/222A9801.jpg" alt="Firearms training course in action" class="w-full h-full object-cover absolute inset-0" />
          <div class="absolute inset-0 bg-black-950/25"></div>
        </div>

        <!-- Text -->
        <div class="px-10 lg:px-16 py-32 flex flex-col justify-center bg-black-950">
          <h2 class="text-3xl md:text-4xl font-bold text-white-100 leading-tight mb-5">
            Great Instructors Don't Always Have Time to Be Marketers.
          </h2>
          <p class="text-white-200/60 text-lg font-sans leading-relaxed mb-8">
            Most training companies run exceptional programs that the right people never hear about. Word of mouth fills some seats. A real content strategy fills the rest. We build the demand creation side so you can stay focused on instruction.
          </p>
          <div class="flex flex-col gap-4">
            {[
              "Promo content built to convert curious browsers into paying students",
              "Platform-safe promotion that won't get your account flagged or buried",
              "A consistent presence that builds trust before they ever show up",
            ].map((item) => (
              <div class="flex items-start gap-4">
                <div class="w-5 h-5 rounded-full bg-brass-500/15 border border-brass-500/40 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-brass-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="text-white-200/70 text-base font-sans leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
          <div class="flex flex-wrap gap-4 mt-10">
            <a href="/contact" class="inline-flex items-center gap-2 bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-8 py-4 uppercase tracking-wider text-sm transition-colors font-sans">
              Let's Talk
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="#work-examples" class="inline-flex items-center gap-2 bg-transparent border border-white-100/30 hover:border-brass-500 text-white-100 hover:text-brass-500 font-bold px-8 py-4 uppercase tracking-wider text-sm transition-colors font-sans">
              See Our Work
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- 3. WORK EXAMPLES GRID -->
    <section id="work-examples" class="bg-black-900 py-20 border-t border-white-100/5">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-10 font-sans">Work Examples</p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {/* Real videos */}
          <div class="video-item cursor-pointer group" data-video-id="GUF35K2MjIo">
            <div class="aspect-video overflow-hidden bg-black-800 relative">
              <img src="https://img.youtube.com/vi/GUF35K2MjIo/maxresdefault.jpg" alt="Utah's Challenge-Based Shooting Competitions | Welcome to The Art Room" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-black-950/60 border border-white-100/20 flex items-center justify-center opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-200">
                  <svg class="w-5 h-5 text-white-100 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <div class="absolute inset-0 bg-black-950/0 group-hover:bg-black-950/60 transition-colors duration-300 flex items-end">
                <p class="text-white-100 font-bold text-xs uppercase tracking-wider p-3 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300 font-sans">The Art Room</p>
              </div>
            </div>
          </div>
          <div class="video-item cursor-pointer group" data-video-id="FVXzgmzPtr8">
            <div class="aspect-video overflow-hidden bg-black-800 relative">
              <img src="https://img.youtube.com/vi/FVXzgmzPtr8/maxresdefault.jpg" alt="Beginner Handgun Class Overview | Nielsen Training" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-black-950/60 border border-white-100/20 flex items-center justify-center opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-200">
                  <svg class="w-5 h-5 text-white-100 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <div class="absolute inset-0 bg-black-950/0 group-hover:bg-black-950/60 transition-colors duration-300 flex items-end">
                <p class="text-white-100 font-bold text-xs uppercase tracking-wider p-3 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300 font-sans">Nielsen Training</p>
              </div>
            </div>
          </div>
          {/* Placeholders */}
          {[
            { img: '/images/still-course-range.jpg',   client: 'Nielsen Training', alt: 'Student shooting pistol at indoor range during Nielsen Training course' },
            { img: '/images/still-course-art-room.jpg', client: 'The Art Room',    alt: 'Shooter firing rifle with brass ejecting at The Art Room class' },
            { img: '/images/noah-instructing.jpg',     client: 'NTAC',             alt: 'NTAC instructor correcting student grip at outdoor firearms course' },
            { img: '/images/222A1518.jpg',             client: 'Iron Rescue',      alt: 'Tactical operator silhouette at sunset during Iron Rescue training' },
          ].map((item) => (
            <div>
              <div class="aspect-video overflow-hidden bg-black-800">
                <img src={item.img} alt={item.alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
              </div>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-3 font-sans">{item.client}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. WHAT'S INCLUDED: 6 ICON CARDS -->
    <section class="bg-black-950 py-20 border-t border-white-100/5">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">What's Included</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white-100 mb-14">Everything You Need. Nothing You Don't.</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white-100/5">

          <!-- Card 1 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Course Promo Video</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">High-production video that sells the experience before students ever show up.</p>
          </div>

          <!-- Card 2 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Social Media Campaign</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Short-form content series built around your course: teasers, class footage, and student POV.</p>
          </div>

          <!-- Card 3 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Landing Page Copy and SEO</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Your course page rewritten to rank on Google and convert when people arrive.</p>
          </div>

          <!-- Card 4 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Student Testimonial Capture</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">We capture testimonials on filming days and turn them into social-ready proof content.</p>
          </div>

          <!-- Card 5 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Email and Enrollment Sequences</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Follow-up messaging and course announcements built to fill seats and keep students coming back.</p>
          </div>

          <!-- Card 6 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Ongoing Content Calendar</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Monthly planning built around your schedule, your courses, and what's actually moving enrollment.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- 5. CONTACT FORM -->
    <Contact />

  </main>
  <Footer />
</Layout>

<!-- Video lightbox modal -->
<div id="video-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background: rgba(10,10,10,0.93);">
  <button id="modal-close" class="absolute top-5 right-5 z-10 w-10 h-10 flex items-center justify-center text-white-100/60 hover:text-white-100 transition-colors" aria-label="Close">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
  <div id="modal-inner" class="relative w-full max-w-4xl aspect-video">
    <iframe id="modal-iframe" class="absolute inset-0 w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
  </div>
</div>

<script>
  const modal = document.getElementById('video-modal') as HTMLElement;
  const iframe = document.getElementById('modal-iframe') as HTMLIFrameElement;

  function openModal(videoId: string) {
    iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    iframe.src = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.video-item').forEach((el) => {
    el.addEventListener('click', () => openModal((el as HTMLElement).dataset.videoId!));
  });

  document.getElementById('modal-close')?.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
</script>
