---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Course Marketing | Blackout Media" description="Turn your firearms course into a content ecosystem that fills seats. Built for ranges, instructors, and training companies.">
  <Nav />
  <main>

    <!-- Hero -->
    <section class="relative min-h-[65vh] flex items-end overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/services-courses.jpg" alt="Course Marketing" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black-950/60"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black-950 via-black-950/30 to-transparent"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 pb-20 pt-32">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">Course Marketing</p>
        <h1 class="text-5xl md:text-6xl font-bold text-white-100 leading-tight mb-4">
          Your Course Is Good.<br />People Just Don't Know It.
        </h1>
        <p class="text-white-200/65 text-xl font-sans max-w-xl">We create the demand. You fill the seats.</p>
      </div>
    </section>

    <!-- Stats strip -->
    <section class="bg-black-900 border-b border-white-100/5">
      <div class="max-w-5xl mx-auto px-6 py-12 grid grid-cols-3 divide-x divide-white-100/10 text-center">
        <div class="px-8">
          <p class="text-5xl font-black text-brass-500 font-heading">170K+</p>
          <p class="text-gray-400 text-xs uppercase tracking-wider mt-2 font-sans">Views on First Video</p>
        </div>
        <div class="px-8">
          <p class="text-5xl font-black text-brass-500 font-heading">$0</p>
          <p class="text-gray-400 text-xs uppercase tracking-wider mt-2 font-sans">Paid Promotion</p>
        </div>
        <div class="px-8">
          <p class="text-5xl font-black text-brass-500 font-heading">3</p>
          <p class="text-gray-400 text-xs uppercase tracking-wider mt-2 font-sans">Active Training Partners</p>
        </div>
      </div>
    </section>

    <!-- Work gallery -->
    <section class="bg-black-950 pt-20 pb-4">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-8 font-sans">Work Samples</p>
      </div>
    </section>
    <section class="bg-black-950 pb-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-1">
        {[
          { img: '/images/services-courses.jpg', label: 'NTAC', sub: 'Course Promo Series' },
          { img: '/images/about-action.jpg', label: 'The Art Room', sub: '170K Views Organic' },
          { img: '/images/noah-rifle.jpg', label: 'Iron Rescue', sub: 'TECC Documentation' },
        ].map((item) => (
          <div class="relative group overflow-hidden" style="aspect-ratio: 4/3;">
            <img src={item.img} alt={item.label} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-black-950/0 group-hover:bg-black-950/70 transition-colors duration-300 flex items-end">
              <div class="p-5 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
                <p class="text-white-100 font-bold text-sm uppercase tracking-wider font-sans">{item.label}</p>
                <p class="text-brass-500 text-xs mt-1 font-sans">{item.sub}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Deliverables list -->
    <section class="bg-black-900 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">What's Delivered</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white-100 mb-10">From Course to Content Ecosystem</h2>
        <div class="flex flex-col divide-y divide-white-100/5">
          {[
            { num: "01", title: "Course Promo Video", tag: "High Production" },
            { num: "02", title: "Social Media Campaign", tag: "Short-Form Series" },
            { num: "03", title: "Landing Page Copy and SEO", tag: "Google-Ready" },
            { num: "04", title: "Student Testimonial Capture", tag: "Social Proof" },
          ].map((item) => (
            <div class="flex items-center gap-6 py-5">
              <span class="text-brass-500 font-bold text-xs font-sans w-6 flex-shrink-0">{item.num}</span>
              <p class="text-white-100 font-bold text-lg flex-1">{item.title}</p>
              <span class="text-gray-400 text-xs uppercase tracking-wider font-sans hidden sm:block">{item.tag}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-black-950 py-20 border-t border-white-100/5">
      <div class="max-w-2xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-white-100 mb-4">Let's Fill Your Next Class</h2>
        <p class="text-white-200/60 text-lg mb-8 font-sans">Tell us about your course. We'll show you what a full content rollout looks like.</p>
        <a href="/contact" class="inline-block bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-10 py-4 uppercase tracking-wider text-sm transition-colors font-sans">
          Get in Touch
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
