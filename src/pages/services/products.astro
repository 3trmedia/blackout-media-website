---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Product Media | Blackout Media" description="Photography and video for firearms manufacturers, retailers, and ranges. Built to move product.">
  <Nav />
  <main>

    <!-- Hero -->
    <section class="relative min-h-[65vh] flex items-end overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/services-products.jpg" alt="Product Media" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black-950/55"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black-950 via-black-950/30 to-transparent"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 pb-20 pt-32">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">Product Media</p>
        <h1 class="text-5xl md:text-6xl font-bold text-white-100 leading-tight mb-4">
          Your Product Photos<br />Are Costing You Sales
        </h1>
        <p class="text-white-200/65 text-xl font-sans max-w-xl">Gear that looks like it belongs in a catalog sells. Gear that looks like a cell phone shot doesn't.</p>
      </div>
    </section>

    <!-- Work gallery — images lead -->
    <section class="bg-black-950 pt-20 pb-4">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-8 font-sans">Work Samples</p>
      </div>
    </section>
    <section class="bg-black-950 pb-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-1">
        {[
          { img: '/images/services-products.jpg', label: 'Rifle and Optics', sub: 'Studio Shoot' },
          { img: '/images/noah-rifle.jpg', label: 'Field Carry', sub: 'Lifestyle Series' },
          { img: '/images/services-sales.jpg', label: 'Gear Lifestyle', sub: 'Field Photography' },
          { img: '/images/about-photo.jpg', label: 'In the Field', sub: 'Brand Content' },
        ].map((item) => (
          <div class="relative group aspect-square overflow-hidden">
            <img src={item.img} alt={item.label} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-black-950/0 group-hover:bg-black-950/70 transition-colors duration-300 flex items-end">
              <div class="p-5 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
                <p class="text-white-100 font-bold text-sm uppercase tracking-wider font-sans">{item.label}</p>
                <p class="text-brass-500 text-xs mt-1 font-sans">{item.sub}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Three formats -->
    <section class="bg-black-900 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">Shoot Formats</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white-100 mb-10">Three Formats. All Deliverable-Ready.</h2>
        <div class="flex flex-col divide-y divide-white-100/5">
          {[
            { num: "01", title: "Studio", tag: "E-Commerce · Ads · Website" },
            { num: "02", title: "Field and Lifestyle", tag: "Social · Brand Campaigns" },
            { num: "03", title: "Short-Form Product Video", tag: "Reels · Shorts · Embeds" },
          ].map((item) => (
            <div class="flex items-center gap-6 py-5">
              <span class="text-brass-500 font-bold text-xs font-sans w-6 flex-shrink-0">{item.num}</span>
              <p class="text-white-100 font-bold text-lg flex-1">{item.title}</p>
              <span class="text-gray-400 text-xs uppercase tracking-wider font-sans hidden sm:block">{item.tag}</span>
            </div>
          ))}
        </div>
        <p class="text-gray-400 text-sm mt-8 font-sans">All assets delivered in web, social, and print-ready formats.</p>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-black-950 py-20 border-t border-white-100/5">
      <div class="max-w-2xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-white-100 mb-4">Let's Make Your Gear Look the Part</h2>
        <p class="text-white-200/60 text-lg mb-8 font-sans">Tell us what you're shooting and what you need it for. We'll handle the rest.</p>
        <a href="/contact" class="inline-block bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-10 py-4 uppercase tracking-wider text-sm transition-colors font-sans">
          Book a Shoot
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
