---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Product Media | Blackout Media" description="Photography and video for firearms manufacturers, retailers, and ranges. Built to move product.">
  <Nav />
  <main>

    <!-- 1. HERO -->
    <section class="relative min-h-[80vh] flex items-center overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/services-products.jpg" alt="Product Media for Firearms" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black-950/70"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black-950/85 via-black-950/50 to-black-950/20"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 pt-24">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white-100 leading-tight mb-5 max-w-3xl">
          Your Gear Deserves Photos That Match Its Quality.
        </h1>
        <h2 class="text-2xl md:text-3xl font-medium text-white-200/70 mb-10 max-w-xl leading-snug">
          We Make Your Product Look Like What It's Worth.
        </h2>
        <a href="/contact" class="inline-flex items-center gap-2 bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-8 py-4 uppercase tracking-wider text-sm transition-colors font-sans">
          Let's Talk
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>

    <!-- 2. PROBLEM STATEMENT — SPLIT -->
    <section class="bg-black-950 border-t border-white-100/5">
      <div class="grid grid-cols-1 lg:grid-cols-2">

        <!-- Image -->
        <div class="relative min-h-[420px] lg:min-h-0">
          <img src="/images/noah-rifle.jpg" alt="Firearms product photography" class="w-full h-full object-cover absolute inset-0" />
          <div class="absolute inset-0 bg-black-950/25"></div>
        </div>

        <!-- Text -->
        <div class="px-10 lg:px-16 py-20 flex flex-col justify-center bg-black-950">
          <h2 class="text-3xl md:text-4xl font-bold text-white-100 leading-tight mb-5">
            Your Product Photos Are the First Sale You Make.
          </h2>
          <p class="text-white-200/60 text-lg font-sans leading-relaxed mb-8">
            Before a customer picks up the phone or clicks add to cart, they've already decided based on what they see. If your gear is shot on a folding table in bad lighting, you're selling against brands that invest in presentation — and you're losing before the conversation starts.
          </p>
          <div class="flex flex-col gap-4">
            {[
              "Studio, field, and lifestyle formats built for every platform and use case",
              "Gear photographed in the environment it was designed to perform in",
              "Delivered in web, social, and print-ready formats at no extra cost",
            ].map((item) => (
              <div class="flex items-start gap-4">
                <div class="w-5 h-5 rounded-full bg-brass-500/15 border border-brass-500/40 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-brass-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="text-white-200/70 text-base font-sans leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- 3. WORK EXAMPLES GRID -->
    <section class="bg-black-900 py-20 border-t border-white-100/5">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-10 font-sans">Work Examples</p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {[
            { img: '/images/services-products.jpg', client: 'Peak Defense Works' },
            { img: '/images/noah-rifle.jpg',        client: 'NTAC' },
            { img: '/images/services-sales.jpg',    client: 'Gear Lifestyle' },
            { img: '/images/about-photo.jpg',       client: 'Field Content' },
            { img: '/images/still-1.jpg',           client: 'NTAC' },
            { img: '/images/about-action.jpg',      client: 'Iron Rescue' },
          ].map((item) => (
            <div>
              <div class="aspect-video overflow-hidden bg-black-800">
                <img src={item.img} alt={item.client} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
              </div>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-3 font-sans">{item.client}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. WHAT'S INCLUDED — 6 ICON CARDS -->
    <section class="bg-black-950 py-20 border-t border-white-100/5">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">What's Included</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white-100 mb-14">Everything You Need. Nothing You Don't.</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white-100/5">

          <!-- Card 1 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><circle cx="12" cy="13" r="3" stroke-width="1.5" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Studio Photography</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Clean, controlled product shots built for e-commerce listings, website pages, and paid ads.</p>
          </div>

          <!-- Card 2 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Field and Lifestyle Shoots</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Your gear in the environment it was designed for — tactical, real, and built to perform on social.</p>
          </div>

          <!-- Card 3 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Short-Form Product Video</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">15–60 second showcases built for Reels, Shorts, and website embeds. Edited and ready to post.</p>
          </div>

          <!-- Card 4 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Brand Asset Delivery</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Every file delivered in web, social, and print-ready formats. No additional editing fees, ever.</p>
          </div>

          <!-- Card 5 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Campaign Coordination</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">We plan the shoot around your product lineup and seasonal calendar so nothing gets wasted.</p>
          </div>

          <!-- Card 6 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Ongoing Media Retainer</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Regular shoot cadence for brands that need a consistent flow of new product and lifestyle content.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- 5. CONTACT FORM -->
    <Contact />

  </main>
  <Footer />
</Layout>
