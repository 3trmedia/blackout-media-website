---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Website Conversion Strategy for Firearms Brands | Blackout Media"
  description="Full-funnel website strategy that turns traffic into leads and sales for firearms manufacturers, ranges, and training companies."
  ogTitle="Blackout Media | Turn Your Website Into a Revenue Engine"
  ogDescription="We audit, rebuild, and optimize websites for the firearms and tactical industry — building funnels that convert visitors into paying customers."
  canonicalUrl="https://www.blackout-media.com/services/website-conversions"
>
  <Nav />
  <main>

    <!-- 1. HERO -->
    <section class="relative min-h-[80vh] flex items-center overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/cta-bg.jpg" alt="Website Conversions for Firearms Businesses" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black-950/70"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black-950/85 via-black-950/50 to-black-950/20"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 pt-24">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white-100 leading-tight mb-5 max-w-3xl">
          Your Website Is Working Against You. Let's Fix That.
        </h1>
        <h2 class="text-2xl md:text-3xl font-medium text-white-200/70 mb-10 max-w-xl leading-snug">
          We Build Sites That Turn Visitors Into Buyers.
        </h2>
        <a href="/contact" class="inline-flex items-center gap-2 bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-8 py-4 uppercase tracking-wider text-sm transition-colors font-sans">
          Let's Talk
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>

    <!-- 2. PROBLEM STATEMENT — SPLIT -->
    <section class="bg-black-950 border-t border-white-100/5">
      <div class="grid grid-cols-1 lg:grid-cols-2">

        <!-- Image -->
        <div class="relative min-h-[420px] lg:min-h-0">
          <img src="/images/about-photo.jpg" alt="Website strategy for firearms brands" class="w-full h-full object-cover absolute inset-0" />
          <div class="absolute inset-0 bg-black-950/25"></div>
        </div>

        <!-- Text -->
        <div class="px-10 lg:px-16 py-20 flex flex-col justify-center bg-black-950">
          <h2 class="text-3xl md:text-4xl font-bold text-white-100 leading-tight mb-5">
            Traffic Doesn't Matter If No One Takes Action.
          </h2>
          <p class="text-white-200/60 text-lg font-sans leading-relaxed mb-8">
            Most firearms businesses have a website. Few have one that actually converts. If people are landing on your site and leaving without calling, booking, or buying — the site is the problem. And it's fixable without starting over from scratch.
          </p>
          <div class="flex flex-col gap-4">
            {[
              "SEO structure that gets you found by the right people in your area",
              "Copy and layout built to convert visitors, not just inform them",
              "No templates — every site built around your specific offer and audience",
            ].map((item) => (
              <div class="flex items-start gap-4">
                <div class="w-5 h-5 rounded-full bg-brass-500/15 border border-brass-500/40 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-brass-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="text-white-200/70 text-base font-sans leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- 3. WORK EXAMPLES GRID -->
    <section class="bg-black-900 py-20 border-t border-white-100/5">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-10 font-sans">Clients We've Built For</p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {[
            { img: '/images/about-photo.jpg',      client: 'Peak Defense Works' },
            { img: '/images/services-sales.jpg',   client: 'NTAC' },
            { img: '/images/cta-bg.jpg',           client: 'Iron Rescue' },
            { img: '/images/services-products.jpg',client: 'Peak Defense Works' },
            { img: '/images/still-1.jpg',          client: 'NTAC' },
            { img: '/images/about-action.jpg',     client: 'Iron Rescue' },
          ].map((item) => (
            <div>
              <div class="aspect-video overflow-hidden bg-black-800">
                <img src={item.img} alt={item.client} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
              </div>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-3 font-sans">{item.client}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. WHAT'S INCLUDED — 6 ICON CARDS -->
    <section class="bg-black-950 py-20 border-t border-white-100/5">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">What's Included</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white-100 mb-14">Everything You Need. Nothing You Don't.</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white-100/5">

          <!-- Card 1 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">SEO Structure</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Keyword targeting, on-page optimization, and technical fixes that get you found by the right people.</p>
          </div>

          <!-- Card 2 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Landing Page Copy</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Every word rewritten around outcomes. Headlines that convert. CTAs that actually get clicked.</p>
          </div>

          <!-- Card 3 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Conversion Optimization</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Layout, flow, and friction audit. We find where people drop off and fix the exact issues holding you back.</p>
          </div>

          <!-- Card 4 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Google Business Optimization</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Local SEO and Google Business profile built to rank for the searches that bring people through your door.</p>
          </div>

          <!-- Card 5 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Shopify and Custom Builds</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">Full site builds from scratch. Product story, site architecture, and media framework all included.</p>
          </div>

          <!-- Card 6 -->
          <div class="bg-black-950 p-10">
            <div class="text-brass-500 mb-7">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
            </div>
            <h3 class="text-white-100 font-bold text-xl mb-3">Product Page Refinement</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-sans">For retailers and manufacturers: product pages rebuilt to close sales, not just display inventory.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- 5. CONTACT FORM -->
    <Contact />

  </main>
  <Footer />
</Layout>
