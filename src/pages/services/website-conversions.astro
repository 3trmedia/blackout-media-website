---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Website Conversions | Blackout Media" description="Your website exists. It's just not working. We fix firearms industry sites that aren't converting.">
  <Nav />
  <main>

    <!-- Hero -->
    <section class="relative min-h-[65vh] flex items-end overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/cta-bg.jpg" alt="Website Conversions" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black-950/65"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black-950 via-black-950/30 to-transparent"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 pb-20 pt-32">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">Website Conversions</p>
        <h1 class="text-5xl md:text-6xl font-bold text-white-100 leading-tight mb-4">
          Your Website Exists.<br />It's Just Not Working.
        </h1>
        <p class="text-white-200/65 text-xl font-sans max-w-xl">We don't just build sites. We fix sites that aren't converting.</p>
      </div>
    </section>

    <!-- Stats strip -->
    <section class="bg-black-900 border-b border-white-100/5">
      <div class="max-w-5xl mx-auto px-6 py-12 grid grid-cols-3 divide-x divide-white-100/10 text-center">
        <div class="px-8">
          <p class="text-5xl font-black text-brass-500 font-heading">3</p>
          <p class="text-gray-400 text-xs uppercase tracking-wider mt-2 font-sans">Sites Built or Fixed</p>
        </div>
        <div class="px-8">
          <p class="text-5xl font-black text-brass-500 font-heading">SEO</p>
          <p class="text-gray-400 text-xs uppercase tracking-wider mt-2 font-sans">Every Page Structured</p>
        </div>
        <div class="px-8">
          <p class="text-5xl font-black text-brass-500 font-heading">0</p>
          <p class="text-gray-400 text-xs uppercase tracking-wider mt-2 font-sans">Templated Builds</p>
        </div>
      </div>
    </section>

    <!-- Featured client split -->
    <section class="bg-black-950 py-20">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-0">
        <div class="relative overflow-hidden" style="min-height: 400px;">
          <img src="/images/about-photo.jpg" alt="Peak Defense Works" class="w-full h-full object-cover absolute inset-0" />
          <div class="absolute inset-0 bg-black-950/40"></div>
        </div>
        <div class="bg-black-900 p-12 flex flex-col justify-center">
          <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">Featured Build</p>
          <h2 class="text-3xl font-bold text-white-100 mb-4">Peak Defense Works</h2>
          <p class="text-white-200/65 text-lg leading-relaxed font-sans mb-6">
            Full Shopify build from scratch. Product story, media framework, and site architecture built to convert traffic into buyers — not just display inventory.
          </p>
          <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] font-sans">Shopify · SEO · Product Copy · Media Framework</p>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-0 mt-1">
        <div class="bg-black-900 p-12 flex flex-col justify-center order-2 lg:order-1">
          <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">SEO and Content</p>
          <h2 class="text-3xl font-bold text-white-100 mb-4">NTAC</h2>
          <p class="text-white-200/65 text-lg leading-relaxed font-sans mb-6">
            Full landing page and SEO build for Nielsen Training. Course pages structured for Google ranking. Beginner Handgun page rebuilt from scratch with proper heading structure and conversion copy.
          </p>
          <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] font-sans">SEO · Landing Pages · Course Conversion</p>
        </div>
        <div class="relative overflow-hidden order-1 lg:order-2" style="min-height: 400px;">
          <img src="/images/services-sales.jpg" alt="NTAC" class="w-full h-full object-cover absolute inset-0" />
          <div class="absolute inset-0 bg-black-950/40"></div>
        </div>
      </div>
    </section>

    <!-- Five levers list -->
    <section class="bg-black-900 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">What We Fix</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white-100 mb-10">Five Levers That Move the Needle</h2>
        <div class="flex flex-col divide-y divide-white-100/5">
          {[
            { num: "01", title: "SEO Structure", tag: "On-Page · Technical · Keywords" },
            { num: "02", title: "Landing Page Copy", tag: "Headlines · CTAs · Conversion" },
            { num: "03", title: "Conversion Optimization", tag: "Layout · Flow · Friction" },
            { num: "04", title: "Google Business Optimization", tag: "Local SEO · Reviews" },
            { num: "05", title: "Product Page Refinement", tag: "Retail · Manufacturers" },
          ].map((item) => (
            <div class="flex items-center gap-6 py-5">
              <span class="text-brass-500 font-bold text-xs font-sans w-6 flex-shrink-0">{item.num}</span>
              <p class="text-white-100 font-bold text-lg flex-1">{item.title}</p>
              <span class="text-gray-400 text-xs uppercase tracking-wider font-sans hidden sm:block">{item.tag}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-black-950 py-20 border-t border-white-100/5">
      <div class="max-w-2xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-white-100 mb-4">Let's Fix What's Broken</h2>
        <p class="text-white-200/60 text-lg mb-8 font-sans">Send us your site. We'll tell you exactly what's holding it back.</p>
        <a href="/contact" class="inline-block bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-10 py-4 uppercase tracking-wider text-sm transition-colors font-sans">
          Get a Free Site Audit
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
