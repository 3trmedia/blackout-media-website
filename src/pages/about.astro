---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="About Blackout Media | Shooters Who Build Brand Content"
  description="Blackout Media was built by people inside the firearms and tactical community. We combine documentary-level production with deep industry knowledge to create content that earns trust."
  ogTitle="About Blackout Media | Industry Insiders, Not Outside Agencies"
  ogDescription="We're not a generalist agency that picked up a firearms client. Blackout Media was built from inside the community: competitive shooters, TECC-certified, and production-trained."
  canonicalUrl="https://www.blackout-media.com/about"
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="relative min-h-[55vh] flex items-end overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/about-action.jpg" alt="Blackout Media" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black-950/65"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black-950 via-black-950/30 to-transparent"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 pb-16 pt-32">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">About</p>
        <h1 class="text-5xl md:text-6xl font-bold text-white-100 leading-tight">
          Built for an Industry<br />Other Agencies Won't Touch
        </h1>
      </div>
    </section>

    <!-- Story -->
    <section class="bg-black-950 py-20">
      <div class="max-w-5xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-6 font-sans">The Story</p>
          <div class="space-y-5 text-white-200/70 text-lg leading-relaxed font-sans">
            <p>
              Blackout Media didn't start as a business plan. It started at a range day in Utah where I met a group of firearms instructors doing serious work and struggling to get anyone to pay attention to it.
            </p>
            <p>
              I'd spent years building content systems for businesses across industries. When I started working with firearms clients, it became clear fast: the platforms were hostile, most agencies wouldn't take the risk, and the few that did had no idea how to communicate to this audience.
            </p>
            <p>
              So I built Blackout Media specifically for this space. Not as a workaround. As a deliberate choice.
            </p>
            <p>
              I hold TECC certification. I shoot regularly. I understand the culture, the gear, and the stakes. When I make content for a training company or a manufacturer, I'm not an outsider trying to translate. I'm already in the room.
            </p>
          </div>
        </div>
        <div class="space-y-6">
          <img src="/images/about-photo.jpg" alt="In the field" class="w-full aspect-[4/3] object-cover" />
          <div class="grid grid-cols-2 gap-4">
            {[
              { label: "TECC Certified", sub: "Tactical Emergency Casualty Care" },
              { label: "Active Shooter", sub: "Performance-oriented approach" },
              { label: "Industry Embedded", sub: "Utah firearms community" },
              { label: "Platform Compliant", sub: "No flags. No bans. Just growth." },
            ].map((c) => (
              <div class="bg-black-900 border border-white-100/5 p-4">
                <p class="text-white-100 font-bold text-sm font-sans">{c.label}</p>
                <p class="text-gray-400 text-xs mt-1 font-sans">{c.sub}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Clients -->
    <section class="bg-black-900 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">Current Clients</p>
        <h2 class="text-3xl font-bold text-white-100 mb-10">Who We Work With</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { name: "NTAC", full: "Nielsen Training and Consulting", desc: "Utah's premier defensive firearms training organization. Full content strategy, filming cadence, and website SEO." },
            { name: "The Art Room", full: "Firearms Range and Experience", desc: "First video produced: 170K+ Instagram views. Ongoing social media and course content." },
            { name: "Iron Rescue", full: "TECC and Emergency Medical Training", desc: "Course documentation, Google Business optimization, and local SEO for Easton's TECC program." },
            { name: "Peak Defense Works", full: "Firearms Retail and Training", desc: "Full Shopify build from scratch. Product story, site architecture, and media framework." },
          ].map((c) => (
            <div class="bg-black-800 border border-white-100/5 p-6">
              <div class="flex items-baseline gap-3 mb-2">
                <span class="text-brass-500 font-bold text-lg font-heading">{c.name}</span>
                <span class="text-gray-400 text-xs uppercase tracking-wider font-sans">{c.full}</span>
              </div>
              <p class="text-white-200/65 text-sm leading-relaxed font-sans">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-black-950 py-20 border-t border-white-100/5">
      <div class="max-w-2xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-white-100 mb-4">Work With Someone Who Gets It</h2>
        <p class="text-white-200/60 text-lg mb-8 font-sans">If your industry, your audience, and your compliance situation matter to you, let's talk.</p>
        <a href="/contact" class="inline-block bg-brass-500 hover:bg-brass-400 text-black-950 font-bold px-10 py-4 uppercase tracking-wider text-sm transition-colors font-sans">
          Get in Touch
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
