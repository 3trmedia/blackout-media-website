---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Blackout Media | Firearms & Tactical Content Production Agency"
  description="Blackout Media produces cinematic video content and marketing for the firearms and tactical industry. We speak the culture, built by shooters for brands that demand credibility."
  ogTitle="Blackout Media | Tactical Industry Content That Converts"
  ogDescription="We create cinematic brand content for firearms companies, gear brands, and tactical training organizations. Credibility-first production from a team that lives the industry."
  canonicalUrl="https://www.blackout-media.com"
>
  <Nav />
  <main>
    <Hero />
    <Services />
    <About />
    <Testimonials />
    <CTA />
    <Contact />
  </main>
  <Footer />
</Layout>
