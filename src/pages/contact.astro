---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact Blackout Media | Free 30-Minute Strategy Call"
  description="Schedule a free 30-minute strategy call with Blackout Media. No sales pitch, just actionable advice for your firearms or tactical brand."
  ogTitle="Get a Free Strategy Call | Blackout Media"
  ogDescription="Talk to a real strategist who lives the industry. Free 30-minute call, no obligation, based in Orem, Utah, available for brands nationwide."
  canonicalUrl="https://www.blackout-media.com/contact"
>
  <Nav />
  <main>

    <section class="bg-black-950 pt-32 pb-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

          <!-- Left -->
          <div>
            <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">Get Started</p>
            <h1 class="text-5xl md:text-6xl font-bold text-white-100 leading-tight mb-6">
              Let's Talk About<br />Your Business
            </h1>
            <p class="text-white-200/65 text-lg leading-relaxed mb-10 font-sans">
              Fill out the form and we'll get back to you within 24 hours. No spam, no pressure. Just a real conversation about what's possible.
            </p>

            <div class="space-y-5">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-brass-500/10 border border-brass-500/30 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-brass-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-gray-400 text-xs uppercase tracking-wider mb-0.5 font-sans">Phone</p>
                  <a href="tel:8019003251" class="text-white-100 font-semibold hover:text-brass-500 transition-colors font-sans">801-900-3251</a>
                </div>
              </div>

              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-brass-500/10 border border-brass-500/30 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-brass-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-gray-400 text-xs uppercase tracking-wider mb-0.5 font-sans">Email</p>
                  <a href="mailto:info@blackout-media.com" class="text-white-100 font-semibold hover:text-brass-500 transition-colors font-sans">info@blackout-media.com</a>
                </div>
              </div>

              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-brass-500/10 border border-brass-500/30 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-brass-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-gray-400 text-xs uppercase tracking-wider mb-0.5 font-sans">Response Time</p>
                  <p class="text-white-100 font-semibold font-sans">Within 24 hours</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Form -->
          <form class="space-y-4" name="contact" method="POST" data-netlify="true">
            <div>
              <label class="block text-white-200/60 text-xs uppercase tracking-wider mb-2 font-sans" for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Your name"
                class="w-full bg-black-800 border border-white-100/10 focus:border-brass-500 text-white-100 placeholder-gray-400 px-4 py-3 outline-none transition-colors text-sm font-sans" />
            </div>
            <div>
              <label class="block text-white-200/60 text-xs uppercase tracking-wider mb-2 font-sans" for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="your@email.com"
                class="w-full bg-black-800 border border-white-100/10 focus:border-brass-500 text-white-100 placeholder-gray-400 px-4 py-3 outline-none transition-colors text-sm font-sans" />
            </div>
            <div>
              <label class="block text-white-200/60 text-xs uppercase tracking-wider mb-2 font-sans" for="website">Website or Social</label>
              <input type="text" id="website" name="website" placeholder="yoursite.com or @handle"
                class="w-full bg-black-800 border border-white-100/10 focus:border-brass-500 text-white-100 placeholder-gray-400 px-4 py-3 outline-none transition-colors text-sm font-sans" />
            </div>
            <div>
              <label class="block text-white-200/60 text-xs uppercase tracking-wider mb-2 font-sans" for="message">Message</label>
              <textarea id="message" name="message" required rows="6"
                placeholder="Tell us about your business and what you're looking to achieve..."
                class="w-full bg-black-800 border border-white-100/10 focus:border-brass-500 text-white-100 placeholder-gray-400 px-4 py-3 outline-none transition-colors text-sm resize-none font-sans"></textarea>
            </div>
            <button type="submit"
              class="w-full bg-brass-500 hover:bg-brass-400 text-black-950 font-black py-4 uppercase tracking-wider text-sm transition-colors flex items-center justify-center gap-2 font-sans">
              Send Message
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </button>
          </form>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
