---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const items = [
  // Regular videos (16:9) — top of grid
  { category: "social",  type: "video",       videoId: "GUF35K2MjIo", label: "Utah's Challenge-Based Shooting Competitions | Welcome to The Art Room" },
  { category: "social",  type: "video",       videoId: "MZJExXX7BbM", label: "This Film Makes Glass Bulletproof | Safe Haven Defense" },
  // NTAC Shorts (9:16)
  { category: "social",  type: "short",       videoId: "tHixxe3-TMY", label: "Move Until You Have a Shot" },
  { category: "social",  type: "short",       videoId: "L331ym3zaDM", label: "Close Quarters Battle Training with NTAC" },
  { category: "social",  type: "short",       videoId: "wdmKtqEerrE", label: "CQB Class with Matt" },
  // Iron Rescue Shorts (9:16)
  { category: "social",  type: "short",       videoId: "QSi4LMuywhs", label: "Running Drills with Iron Rescue" },
  { category: "social",  type: "short",       videoId: "aQjAKf1zX5Y", label: "Ropes Medical Rescue" },
  // The Art Room Shorts (9:16)
  { category: "social",  type: "short",       videoId: "ZAG1YsQuIFM", label: "Extreme Rappelling in Utah" },
  { category: "social",  type: "short",       videoId: "2kmng-wbH_o", label: "Rappelling & Shooting with The Art Room" },
  { category: "course",  type: "short",       videoId: "le59ALtuqBc", label: "The Art Room's Ultimate Training Experience" },
  { category: "course",  type: "short",       videoId: "L4QsDWz4d1A", label: "Night Vision Course at The Art Room" },
  // Course placeholders
  { category: "course",  type: "placeholder", img: "/images/services-courses.jpg",  label: "NTAC Beginner Handgun Promo" },
  { category: "course",  type: "placeholder", img: "/images/about-action.jpg",      label: "The Art Room Course Promo" },
  { category: "course",  type: "placeholder", img: "/images/noah-rifle.jpg",        label: "Iron Rescue TECC Documentation" },
  // Website builds
  { category: "website", type: "placeholder", img: "/images/web-peak-defense.png",  label: "Peak Defense Works" },
  { category: "website", type: "placeholder", img: "/images/web-ntac.png",          label: "NTAC" },
  { category: "website", type: "placeholder", img: "/images/web-iron-rescue.png",   label: "Iron Rescue" },
];
---

<Layout
  title="Portfolio | Firearms & Tactical Brand Content | Blackout Media Utah"
  description="See how Blackout Media helps Utah gun brands, training companies, and ranges grow with cinematic video, product content, and social media built for the 2A industry."
  ogTitle="Real Work for Real Tactical Brands | Blackout Media"
  ogDescription="See how Blackout Media helps Utah gun brands, training companies, and ranges grow with cinematic video, product content, and social media built for the 2A industry."
  canonicalUrl="https://www.blackout-media.com/portfolio"
>
  <Nav />
  <main>

    <!-- Header -->
    <section class="bg-black-950 pt-32 pb-16">
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">Our Work</p>
        <h1 class="text-5xl md:text-6xl font-bold text-white-100 mb-4">Portfolio</h1>
        <p class="text-white-200/60 text-xl font-sans max-w-xl">Work produced for firearms ranges, training companies, and manufacturers.</p>
      </div>
    </section>

    <!-- Filter + Grid -->
    <section class="bg-black-950 pb-24">
      <div class="max-w-7xl mx-auto px-6">

        <!-- Filter buttons -->
        <div class="flex flex-wrap gap-2 mb-10" id="filters">
          {[
            { key: "all",     label: "All Work" },
            { key: "social",  label: "Social Media" },
            { key: "course",  label: "Course Promo" },
            { key: "website", label: "Website" },
          ].map((f) => (
            <button
              data-filter={f.key}
              class={`filter-btn px-5 py-2 text-xs uppercase tracking-wider font-bold font-sans border transition-colors ${f.key === 'all' ? 'bg-brass-500 border-brass-500 text-black-950' : 'bg-transparent border-white-100/20 text-gray-400 hover:border-brass-500 hover:text-brass-500'}`}
            >
              {f.label}
            </button>
          ))}
        </div>

        <!-- Portfolio grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-1" id="portfolio-grid">
          {items.map((item) => {
            const isVideo = item.type === 'short' || item.type === 'video';
            const imgSrc = isVideo
              ? `https://img.youtube.com/vi/${item.videoId}/maxresdefault.jpg`
              : (item as any).img;
            const aspectClass = 'aspect-square';

            return (
              <div
                class="portfolio-item"
                data-category={item.category}
                data-video-id={isVideo ? item.videoId : undefined}
                data-video-type={isVideo ? item.type : undefined}
                data-img={!isVideo ? (item as any).img : undefined}
                data-img-type={!isVideo ? item.category : undefined}
              >
                <div class={`relative group overflow-hidden cursor-pointer ${aspectClass}`}>
                  <img
                    src={imgSrc}
                    alt={item.label}
                    class={`w-full h-full object-cover transition-transform duration-500 ${item.type === 'short' ? 'scale-[1.8] group-hover:scale-[1.89]' : 'group-hover:scale-105'}`}
                  />
                  {isVideo && (
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="w-12 h-12 rounded-full bg-black-950/60 border border-white-100/20 flex items-center justify-center opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-200">
                        <svg class="w-5 h-5 text-white-100 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M8 5v14l11-7z"/>
                        </svg>
                      </div>
                    </div>
                  )}
                  <div class="absolute inset-0 bg-black-950/0 group-hover:bg-black-950/60 transition-colors duration-300 flex items-end">
                    <p class="text-white-100 font-bold text-xs uppercase tracking-wider p-3 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300 font-sans">
                      {item.label}
                    </p>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<!-- Video lightbox modal -->
<div id="video-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background: rgba(10,10,10,0.93);">
  <button id="modal-close" class="absolute top-5 right-5 z-10 w-10 h-10 flex items-center justify-center text-white-100/60 hover:text-white-100 transition-colors" aria-label="Close">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
  <div id="modal-inner" class="relative w-full max-w-sm aspect-[9/16]">
    <iframe
      id="modal-iframe"
      class="absolute inset-0 w-full h-full"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
</div>

<!-- Photo lightbox modal (centered, fits viewport) -->
<div id="photo-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background: rgba(10,10,10,0.93);">
  <button id="photo-modal-close" class="absolute top-5 right-5 z-10 w-10 h-10 flex items-center justify-center text-white-100/60 hover:text-white-100 transition-colors" aria-label="Close">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
  <img id="photo-modal-img" src="" alt="" class="max-w-full max-h-[85vh] w-auto h-auto object-contain block" />
</div>

<!-- Website screenshot modal (scrollable, full width) -->
<div id="website-modal" class="hidden fixed inset-0 z-50 overflow-y-auto" style="background: rgba(10,10,10,0.95);">
  <div class="flex justify-center p-4 pt-12 min-h-full">
    <button id="website-modal-close" class="fixed top-5 right-5 z-10 w-10 h-10 flex items-center justify-center text-white-100/60 hover:text-white-100 transition-colors" aria-label="Close">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <div class="w-full max-w-4xl">
      <img id="website-modal-img" src="" alt="" class="w-full h-auto block" />
    </div>
  </div>
</div>

<script>
  // Filter
  const btns = document.querySelectorAll('.filter-btn');
  const portfolioItems = document.querySelectorAll('.portfolio-item');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;
      btns.forEach((b) => {
        b.classList.remove('bg-brass-500', 'border-brass-500', 'text-black-950');
        b.classList.add('bg-transparent', 'border-white-100/20', 'text-gray-400');
      });
      btn.classList.add('bg-brass-500', 'border-brass-500', 'text-black-950');
      btn.classList.remove('bg-transparent', 'border-white-100/20', 'text-gray-400');

      portfolioItems.forEach((item) => {
        const el = item as HTMLElement;
        const show = filter === 'all' || el.dataset.category === filter;
        el.style.display = show ? '' : 'none';
      });
    });
  });

  // Video lightbox
  const videoModal = document.getElementById('video-modal') as HTMLElement;
  const modalInner = document.getElementById('modal-inner') as HTMLElement;
  const iframe = document.getElementById('modal-iframe') as HTMLIFrameElement;

  function openVideoModal(videoId: string, videoType: string) {
    if (videoType === 'short') {
      modalInner.className = 'relative w-full max-w-sm aspect-[9/16]';
    } else {
      modalInner.className = 'relative w-full max-w-4xl aspect-video';
    }
    iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
    videoModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeVideoModal() {
    videoModal.classList.add('hidden');
    iframe.src = '';
    document.body.style.overflow = '';
  }

  // Photo lightbox (centered, fits viewport)
  const photoModal = document.getElementById('photo-modal') as HTMLElement;
  const photoModalImg = document.getElementById('photo-modal-img') as HTMLImageElement;

  function openPhotoModal(img: string, alt: string) {
    photoModalImg.src = img;
    photoModalImg.alt = alt;
    photoModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closePhotoModal() {
    photoModal.classList.add('hidden');
    photoModalImg.src = '';
    document.body.style.overflow = '';
  }

  // Website screenshot modal (scrollable, full width)
  const websiteModal = document.getElementById('website-modal') as HTMLElement;
  const websiteModalImg = document.getElementById('website-modal-img') as HTMLImageElement;

  function openWebsiteModal(img: string, alt: string) {
    websiteModalImg.src = img;
    websiteModalImg.alt = alt;
    websiteModal.classList.remove('hidden');
    websiteModal.scrollTop = 0;
  }

  function closeWebsiteModal() {
    websiteModal.classList.add('hidden');
    websiteModalImg.src = '';
  }

  // Wire up all portfolio item clicks
  portfolioItems.forEach((item) => {
    const el = item as HTMLElement;
    if (el.dataset.videoId) {
      el.addEventListener('click', () => openVideoModal(el.dataset.videoId!, el.dataset.videoType!));
    } else if (el.dataset.img) {
      el.addEventListener('click', () => {
        if (el.dataset.imgType === 'website') {
          openWebsiteModal(el.dataset.img!, el.querySelector('img')?.alt || '');
        } else {
          openPhotoModal(el.dataset.img!, el.querySelector('img')?.alt || '');
        }
      });
    }
  });

  // Close handlers
  document.getElementById('modal-close')?.addEventListener('click', closeVideoModal);
  videoModal.addEventListener('click', (e) => { if (e.target === videoModal) closeVideoModal(); });

  document.getElementById('photo-modal-close')?.addEventListener('click', closePhotoModal);
  photoModal.addEventListener('click', (e) => { if (e.target === photoModal) closePhotoModal(); });

  document.getElementById('website-modal-close')?.addEventListener('click', closeWebsiteModal);
  websiteModal.addEventListener('click', (e) => { if (e.target === websiteModal) closeWebsiteModal(); });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeVideoModal(); closePhotoModal(); closeWebsiteModal(); }
  });
</script>
