---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const items = [
  // NTAC
  { category: "social", videoId: "tHixxe3-TMY", url: "https://youtube.com/shorts/tHixxe3-TMY", label: "NTAC Range Day Hype Reel" },
  { category: "social", videoId: "L331ym3zaDM", url: "https://youtube.com/shorts/L331ym3zaDM", label: "NTAC Training Content" },
  { category: "social", videoId: "wdmKtqEerrE", url: "https://youtube.com/shorts/wdmKtqEerrE", label: "NTAC Course Promo" },
  // Iron Rescue
  { category: "social", videoId: "8gnI4TjH89s", url: "https://youtube.com/shorts/8gnI4TjH89s", label: "Iron Rescue Social Content" },
  { category: "social", videoId: "tACbnSZjb24", url: "https://youtube.com/shorts/tACbnSZjb24", label: "Iron Rescue Training Reel" },
  { category: "social", videoId: "QSi4LMuywhs", url: "https://youtube.com/shorts/QSi4LMuywhs", label: "Iron Rescue TECC Content" },
  { category: "social", videoId: "aQjAKf1zX5Y", url: "https://youtube.com/shorts/aQjAKf1zX5Y", label: "Iron Rescue Course Promo" },
  { category: "social", videoId: "bo4NmAJUBSk", url: "https://youtube.com/shorts/bo4NmAJUBSk", label: "Iron Rescue Promo" },
  { category: "social", videoId: "uH3W_2dGgD4", url: "https://youtube.com/shorts/uH3W_2dGgD4", label: "Iron Rescue Social" },
  // The Art Room
  { category: "social", videoId: "GUF35K2MjIo", url: "https://youtu.be/GUF35K2MjIo", label: "The Art Room: 170K Views" },
  // Peak Defense Works
  { category: "website", videoId: "Xt1wZXrDSKs", url: "https://youtu.be/Xt1wZXrDSKs", label: "Peak Defense Works" },
  // Placeholders
  { category: "social",   img: "/images/services-social.jpg",   label: "Tactical Content Series" },
  { category: "course",   img: "/images/services-courses.jpg",  label: "NTAC Beginner Handgun Promo" },
  { category: "course",   img: "/images/about-action.jpg",      label: "The Art Room Course Promo" },
  { category: "course",   img: "/images/noah-rifle.jpg",        label: "Iron Rescue TECC Documentation" },
  { category: "product",  img: "/images/services-products.jpg", label: "Rifle and Optic Product Shoot" },
  { category: "product",  img: "/images/services-sales.jpg",    label: "Gear Lifestyle Photography" },
  { category: "website",  img: "/images/about-photo.jpg",       label: "NTAC Website Rebuild" },
];
---

<Layout
  title="Portfolio | Firearms & Tactical Brand Content | Blackout Media Utah"
  description="See how Blackout Media helps Utah gun brands, training companies, and ranges grow with cinematic video, product content, and social media built for the 2A industry."
  ogTitle="Real Work for Real Tactical Brands | Blackout Media"
  ogDescription="See how Blackout Media helps Utah gun brands, training companies, and ranges grow with cinematic video, product content, and social media built for the 2A industry."
  canonicalUrl="https://www.blackout-media.com/portfolio"
>
  <Nav />
  <main>

    <!-- Header -->
    <section class="bg-black-950 pt-32 pb-16">
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-brass-500 text-xs font-semibold uppercase tracking-[0.3em] mb-4 font-sans">Our Work</p>
        <h1 class="text-5xl md:text-6xl font-bold text-white-100 mb-4">Portfolio</h1>
        <p class="text-white-200/60 text-xl font-sans max-w-xl">Work produced for firearms ranges, training companies, and manufacturers.</p>
      </div>
    </section>

    <!-- Filter + Grid -->
    <section class="bg-black-950 pb-24">
      <div class="max-w-7xl mx-auto px-6">

        <!-- Filter buttons -->
        <div class="flex flex-wrap gap-2 mb-10" id="filters">
          {[
            { key: "all",     label: "All Work" },
            { key: "social",  label: "Social Media" },
            { key: "course",  label: "Course Promo" },
            { key: "product", label: "Product Media" },
            { key: "website", label: "Website" },
          ].map((f) => (
            <button
              data-filter={f.key}
              class={`filter-btn px-5 py-2 text-xs uppercase tracking-wider font-bold font-sans border transition-colors ${f.key === 'all' ? 'bg-brass-500 border-brass-500 text-black-950' : 'bg-transparent border-white-100/20 text-gray-400 hover:border-brass-500 hover:text-brass-500'}`}
            >
              {f.label}
            </button>
          ))}
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-1" id="portfolio-grid">
          {items.map((item) => {
            const imgSrc = item.videoId
              ? `https://img.youtube.com/vi/${item.videoId}/hqdefault.jpg`
              : item.img;
            const isVideo = !!item.videoId;

            const inner = (
              <div
                data-category={item.category}
                class="portfolio-item relative group overflow-hidden aspect-square"
              >
                <img
                  src={imgSrc}
                  alt={item.label}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                {isVideo && (
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                    <div class="w-10 h-10 rounded-full bg-black-950/60 flex items-center justify-center opacity-70 group-hover:opacity-100 transition-opacity">
                      <svg class="w-4 h-4 text-white-100 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                )}
                <div class="absolute inset-0 bg-black-950/0 group-hover:bg-black-950/70 transition-colors duration-300 flex items-end">
                  <p class="text-white-100 font-bold text-sm uppercase tracking-wider p-4 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300 font-sans">
                    {item.label}
                  </p>
                </div>
              </div>
            );

            return isVideo ? (
              <a href={item.url} target="_blank" rel="noopener noreferrer" data-category={item.category} class="portfolio-item block">
                <div class="relative group overflow-hidden aspect-square">
                  <img
                    src={imgSrc}
                    alt={item.label}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                    <div class="w-10 h-10 rounded-full bg-black-950/60 flex items-center justify-center opacity-70 group-hover:opacity-100 transition-opacity">
                      <svg class="w-4 h-4 text-white-100 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="absolute inset-0 bg-black-950/0 group-hover:bg-black-950/70 transition-colors duration-300 flex items-end">
                    <p class="text-white-100 font-bold text-sm uppercase tracking-wider p-4 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300 font-sans">
                      {item.label}
                    </p>
                  </div>
                </div>
              </a>
            ) : (
              <div
                data-category={item.category}
                class="portfolio-item relative group overflow-hidden aspect-square"
              >
                <img
                  src={imgSrc}
                  alt={item.label}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-black-950/0 group-hover:bg-black-950/70 transition-colors duration-300 flex items-end">
                  <p class="text-white-100 font-bold text-sm uppercase tracking-wider p-4 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300 font-sans">
                    {item.label}
                  </p>
                </div>
              </div>
            );
          })}
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  const btns = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.portfolio-item');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      btns.forEach((b) => {
        b.classList.remove('bg-brass-500', 'border-brass-500', 'text-black-950');
        b.classList.add('bg-transparent', 'border-white-100/20', 'text-gray-400');
      });
      btn.classList.add('bg-brass-500', 'border-brass-500', 'text-black-950');
      btn.classList.remove('bg-transparent', 'border-white-100/20', 'text-gray-400');

      items.forEach((item) => {
        const el = item as HTMLElement;
        if (filter === 'all' || el.dataset.category === filter) {
          el.style.display = 'block';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>
